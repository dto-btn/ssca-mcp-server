# Orchestrator LLM-first classification (Azure OpenAI)
# Copy these from ssc-assistant/app/api/.env when possible.
ENABLE_LLM_CLASSIFIER=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_VERSION=2024-05-01-preview
# Optional if you already set `GPT40_DEPLOYMENT_NAME` or `DEFAULT_DEPLOYMENT_NAME`
ORCHESTRATOR_LLM_MODEL=
ORCHESTRATOR_LLM_TIMEOUT_SECONDS=8.0

# Shared deployment names (same pattern as SSC Assistant API)
GPT40_DEPLOYMENT_NAME=
DEFAULT_DEPLOYMENT_NAME=

# Azure AD names copied from SSC Assistant API env
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=

# Routing behavior
ORCHESTRATOR_MIN_CONFIDENCE=0.4
