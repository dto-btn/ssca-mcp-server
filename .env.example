# Orchestrator LLM-first classification via SSC embedded LiteLLM proxy
ENABLE_LLM_CLASSIFIER=false
# Example: http://localhost:5001/proxy/litellm/v1
ORCHESTRATOR_LITELLM_PROXY_URL=http://localhost:5001/proxy/litellm/v1
# Optional static bearer token for proxy auth (Authorization: Bearer ...)
ORCHESTRATOR_LITELLM_PROXY_BEARER_TOKEN=
# Optional scope for DefaultAzureCredential token acquisition to call proxy.
# If omitted, defaults to api://$AZURE_AD_CLIENT_ID/.default when AZURE_AD_CLIENT_ID is set.
ORCHESTRATOR_LITELLM_PROXY_SCOPE=
# Optional for standalone/external proxy modes that enforce API keys
ORCHESTRATOR_LITELLM_PROXY_API_KEY=
# Model name exposed by LiteLLM (for example: azure/gpt-4o or gpt-4o-mini)
ORCHESTRATOR_LLM_MODEL=
ORCHESTRATOR_LLM_TIMEOUT_SECONDS=8.0

# Shared deployment names (same pattern as SSC Assistant API)
GPT40_DEPLOYMENT_NAME=
DEFAULT_DEPLOYMENT_NAME=

# Azure AD names copied from SSC Assistant API env
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=

# Routing behavior
ORCHESTRATOR_MIN_CONFIDENCE=0.4
