{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MCP: Playground Orchestrator (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "preLaunchTask": "Generate local self-signed cert",
      "cwd": "${workspaceFolder}",
      "module": "uvicorn",
      "args": [
        "src.server.server:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--timeout-graceful-shutdown",
        "2"
      ],
      "console": "integratedTerminal",
      "env": {
        "ORCHESTRATOR_ALLOWED_ORIGINS": "http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,https://localhost:8080,https://127.0.0.1:8080,https://localhost:5173,https://127.0.0.1:5173",
        "ORCHESTRATOR_AUTO_TLS": "false"
      }
    }
  ]
}
